# MEBLI-PRO — Environment Variables
# ══════════════════════════════════════════

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Telegram Bot ───
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
ADMIN_CHAT_ID=123456789

# ─── Admin Panel ───
ADMIN_PASSWORD=your-strong-password

# ─── Site URL ───
NEXT_PUBLIC_SITE_URL=https://mebli-pro.com.ua

# ─── Email (SMTP — HostIQ) ───
SMTP_HOST=mail.your-domain.com.ua
SMTP_PORT=465
SMTP_USER=info@your-domain.com.ua
SMTP_PASS=your-email-password
SMTP_FROM=info@your-domain.com.ua
ADMIN_EMAIL=meblipro2025@gmail.com
